cat > .env.example << 'EOF'
# Groq API key for OCR (vision) and structured extraction (text)
# Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_generated_secret_here

# Database connection string
# Local dev: leave unset to use SQLite automatically
# Production: postgresql://user:password@host/dbname
DATABASE_URL=

# Comma-separated list of allowed frontend origins for CORS
# Leave unset for local dev (defaults to http://localhost:5173)
FRONTEND_ORIGIN=
EOF